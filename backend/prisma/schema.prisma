// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === СПРАВОЧНИКИ ===

model Zone {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  cells     Cell[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Cell {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  zoneId    Int
  zone      Zone      @relation(fields: [zoneId], references: [id])
  items     Inventory[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model InventoryType {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(100)
  items     Inventory[]
  receipts  ReceiptItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(200)
  receipts  Receipt[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Employee {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(100)
  role      String      @db.VarChar(50)
  email     String      @db.VarChar(100) @unique
  password  String      @db.VarChar(255)
  contracts RentalContract[]
  movements InventoryMovement[]
  tasks     AssemblyTask[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Customer {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(100)
  phone     String      @db.VarChar(20)
  email     String?     @db.VarChar(100)
  contracts RentalContract[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// === ОСНОВНЫЕ СУЩНОСТИ ===

model Inventory {
  id        Int               @id @default(autoincrement())
  name      String            @db.VarChar(200)
  typeId    Int
  type      InventoryType     @relation(fields: [typeId], references: [id])
  cellId    Int
  cell      Cell              @relation(fields: [cellId], references: [id])
  status    String            @db.VarChar(50) @default("available")
  rentalItems     RentalContractItem[]
  movements       InventoryMovement[]
  inventoryChecks InventoryCheckItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RentalContract {
  id        Int               @id @default(autoincrement())
  number    String            @db.VarChar(50) @unique
  customerId Int
  customer  Customer          @relation(fields: [customerId], references: [id])
  employeeId Int
  employee  Employee          @relation(fields: [employeeId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    String            @db.VarChar(50) @default("active")
  items     RentalContractItem[]
  payments  Payment[]
  assemblyTask AssemblyTask?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model RentalContractItem {
  id         Int            @id @default(autoincrement())
  contractId Int
  contract   RentalContract @relation(fields: [contractId], references: [id])
  inventoryId Int
  inventory  Inventory      @relation(fields: [inventoryId], references: [id])
  quantity   Int            @default(1)
  createdAt  DateTime       @default(now())
}

model Payment {
  id         Int            @id @default(autoincrement())
  contractId Int
  contract   RentalContract @relation(fields: [contractId], references: [id])
  amount     Decimal        @db.Decimal(10, 2)
  type       String         @db.VarChar(50) // deposit, rent, penalty
  paidAt     DateTime       @default(now())
  createdAt  DateTime       @default(now())
}

model AssemblyTask {
  id         Int            @id @default(autoincrement())
  contractId Int            @unique
  contract   RentalContract @relation(fields: [contractId], references: [id])
  employeeId Int
  employee   Employee       @relation(fields: [employeeId], references: [id])
  status     String         @db.VarChar(50) @default("pending")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

// === ОПЕРАЦИИ ===

model Receipt {
  id        Int       @id @default(autoincrement())
  number    String    @db.VarChar(50) @unique
  supplierId Int
  supplier  Supplier  @relation(fields: [supplierId], references: [id])
  date      DateTime  @default(now())
  items     ReceiptItem[]
  createdAt DateTime  @default(now())
}

model ReceiptItem {
  id        Int       @id @default(autoincrement())
  receiptId Int
  receipt   Receipt   @relation(fields: [receiptId], references: [id])
  typeId    Int
  type      InventoryType @relation(fields: [typeId], references: [id])
  quantity  Int
  price     Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now())
}

model InventoryMovement {
  id          Int       @id @default(autoincrement())
  inventoryId Int
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id])
  type        String    @db.VarChar(50) // receipt, rental, return, move, writeoff
  quantity    Int
  note        String?   @db.Text
  createdAt   DateTime  @default(now())
}

model InventoryCheck {
  id        Int                @id @default(autoincrement())
  number    String             @db.VarChar(50) @unique
  date      DateTime           @default(now())
  status    String             @db.VarChar(50) @default("in_progress")
  items     InventoryCheckItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model InventoryCheckItem {
  id        Int              @id @default(autoincrement())
  checkId   Int
  check     InventoryCheck   @relation(fields: [checkId], references: [id])
  inventoryId Int
  inventory Inventory        @relation(fields: [inventoryId], references: [id])
  expected  Int
  actual    Int
  createdAt DateTime         @default(now())
}